rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /users/{userId}/avatar/{fileName} {
      allow read: if fileName in ['avatar.jpg', 'avatar.png', 'avatar.webp'];
      allow create, update: if request.auth != null && request.auth.uid == userId
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/(jpeg|png|webp)')
                            && fileName in ['avatar.jpg', 'avatar.png', 'avatar.webp'];
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /kyc/{userId}/{fileName} {
      function isAdmin() {
        return request.auth != null && (
          request.auth.token.get('isAdmin', false) == true ||
          request.auth.token.get('role', '') == 'admin' ||
          (request.auth.uid != null &&
           firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
           firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
        );
      }

      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin())
                  && fileName in ['identity_document.jpg', 'identity_document.jpeg', 'identity_document.png', 'identity_document.webp', 'identity_document.pdf'];
      allow create: if request.auth != null && request.auth.uid == userId
                    && resource == null
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|png|webp)|application/pdf')
                    && fileName in ['identity_document.jpg', 'identity_document.jpeg', 'identity_document.png', 'identity_document.webp', 'identity_document.pdf'];
      allow update: if false;
      allow delete: if request.auth != null && isAdmin();
    }
  }
}
