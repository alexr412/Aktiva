rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    match /activities/{activityId} {
      allow read: if request.auth != null;
      
      // Users can only create an activity if they are the creator listed in the document
      allow create: if request.auth.uid != null && request.resource.data.creatorId == request.auth.uid;

      // Allow participants to update to join, vote, or complete.
      // This is permissive for now to facilitate development.
      allow update: if request.auth.uid != null && (
        get(/databases/$(database)/documents/activities/$(activityId)).data.participantIds.hasAny([request.auth.uid])
        || request.resource.data.participantIds.hasAny([request.auth.uid])
      );

      // Anyone in the activity can delete it (based on UI in chat info sheet)
      allow delete: if request.auth.uid != null && resource.data.participantIds.hasAny([request.auth.uid]);
    }

    match /chats/{chatId} {
       // Temporarily allow any authenticated user to read/write for debugging.
       allow read, write: if request.auth != null;

       match /messages/{messageId} {
          // Temporarily allow any authenticated user to read/write for debugging.
          allow read, write: if request.auth != null;
       }
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      // Users can only create a review if they are the reviewer
      // And they were part of the activity
      allow create: if request.auth.uid != null 
                    && request.resource.data.reviewerId == request.auth.uid
                    && get(/databases/$(database)/documents/activities/$(request.resource.data.activityId)).data.participantIds.hasAny([request.auth.uid]);
      // Reviews are immutable
      allow update, delete: if false;
    }
  }
}
