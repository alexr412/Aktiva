rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserData().role == 'admin' || 
        getUserData().isAdmin == true || // Legacy support
        request.auth.token.isAdmin == true
      );
    }

    function isFieldUnchanged(fieldName) {
      return !(fieldName in request.resource.data) || 
        (fieldName in resource.data && request.resource.data[fieldName] == resource.data[fieldName]);
    }

    // Verhindert das Ändern von Systemfeldern durch den Client
    function hasNoSystemFieldChanges() {
      let systemFields = [
        'role', 'isAdmin', 'isBanned', 'escrowBalance', 'fiatBalance', 
        'tokens', 'successfulFreeHosts', 'kycStatus', 'ratingCount', 'averageRating'
      ];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(systemFields);
    }

    // Stellt sicher, dass unveränderliche Finanzfelder nach der Erstellung nicht geändert werden können
    function hasNoImmutableFinancialFieldChanges() {
      let immutableFields = ['price', 'isPaid', 'hostId', 'currency', 'paymentConfig'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(immutableFields);
    }

    // Stellt sicher, dass Teilnehmer nur erlaubte Felder ändern und nur ihre eigene UID verwenden
    function isParticipantAllowedUpdate() {
      let uid = request.auth.uid;
      let allowedKeys = ['participantIds', 'participantsPreview', 'participantDetails', 'completionVotes', 'lastInteractionAt'];
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      // Nur erlaubte Keys dürfen sich ändern
      let onlyAllowedKeys = changedKeys.hasOnly(allowedKeys);
      // participantIds darf nur die eigene UID des Nutzers hinzufügen oder entfernen
      let pidsBefore = resource.data.get('participantIds', []);
      let pidsAfter = request.resource.data.get('participantIds', []);
      let pidDiff = pidsAfter.removeAll(pidsBefore).concat(pidsBefore.removeAll(pidsAfter));
      let onlyOwnUidInPids = !changedKeys.hasAny(['participantIds']) || (pidDiff.size() == 1 && pidDiff[0] == uid);
      // completionVotes darf nur die eigene UID des Nutzers hinzufügen
      let votesBefore = resource.data.get('completionVotes', []);
      let votesAfter = request.resource.data.get('completionVotes', []);
      let voteDiff = votesAfter.removeAll(votesBefore);
      let onlyOwnUidInVotes = !changedKeys.hasAny(['completionVotes']) || (votesAfter.size() >= votesBefore.size() && voteDiff.size() == 1 && voteDiff[0] == uid);
      return onlyAllowedKeys && onlyOwnUidInPids && onlyOwnUidInVotes;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
        request.resource.data.role == 'user' && 
        request.resource.data.isBanned == false &&
        request.resource.data.escrowBalance == 0;
      allow update: if (isOwner(userId) && hasNoSystemFieldChanges()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if true; // Öffentlich findbar
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      // Host: Darf alles ändern außer unveränderliche Finanzfelder
      // Participant: Darf ausschließlich eigene, erlaubte Felder über Allowlist mutieren
      allow update: if isSignedIn() && (
        (resource.data.hostId == request.auth.uid && hasNoImmutableFinancialFieldChanges()) ||
        (resource.data.participantIds.hasAny([request.auth.uid]) && isParticipantAllowedUpdate()) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.hostId == request.auth.uid || isAdmin());
      
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == participantId || isAdmin());
      }
    }

    match /chats/{chatId} {
      // Nur Teilnehmer dürfen den Chat-Metadaten-Doc lesen
      allow read: if isSignedIn() && (
        resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin()
      );
      // Erstellung nur wenn man selbst Teilnehmer ist
      allow create: if isSignedIn() && request.resource.data.participantIds.hasAny([request.auth.uid]);
      // Update nur für Teilnehmer (z.B. unreadCount oder neue Teilnehmer via Transaction)
      allow update: if isSignedIn() && (
        resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin()
      );
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        // Nur Teilnehmer dürfen Nachrichten lesen und schreiben
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) || 
          isAdmin()
        );
      }
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn(); // Erlaubt anderen, Notifications zu triggern (z.B. Join)
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /places/{placeId} {
      allow read: if true;
      // Feld-Level Security für Places: Verhindert Manipulation von Scores durch direkte API-Writes
      allow write: if isSignedIn() && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['communityScore', 'globalScore', 'activityCount']) ||
        isAdmin()
      );
    }

    match /payoutRequests/{requestId} {
      // Erstellung NUR durch Admin SDK (Cloud Functions). Kein direkter Client-Zugriff.
      allow create: if false;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /refunds/{refundId} {
      // Erstellung NUR durch Admin SDK (Cloud Functions). Kein direkter Client-Zugriff.
      allow create: if false;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Append-only Finanzledger: Kein Update/Delete erlaubt, auch nicht für Admins
    match /financial_ledger/{entryId} {
      allow create: if false; // Nur via Admin SDK (Cloud Functions)
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // Idempotenz-Collections: Nur Admin SDK darf schreiben
    match /processed_payments/{docId} {
      allow create: if false;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /processed_operations/{docId} {
      allow create: if false;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // Dead-Letter Queue: Nur Admin SDK darf schreiben; Admins dürfen lesen für Forensik
    match /failed_operations/{docId} {
      allow create: if false;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
    
    match /kycRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telemetry_events/{eventId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
