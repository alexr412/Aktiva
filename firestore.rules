rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /activities/{activityId} {
      // Allow authenticated users to read all activities.
      allow read: if request.auth != null;
      
      // Allow authenticated users to create an activity if they are the creator.
      allow create: if request.auth != null 
                    && request.resource.data.creatorId == request.auth.uid;
      
      // Allow participants to update (join/leave) an activity, or the creator to delete it.
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }

    match /chats/{chatId} {
       // Allow authenticated users to create a chat if they are a participant.
      allow create: if request.auth != null 
                    && request.auth.uid in request.resource.data.participantIds;
      
      // Allow participants to read, update, or delete a chat document.
      allow read, update, delete: if request.auth != null 
                                 && request.auth.uid in resource.data.participantIds;
    }
  }
}
