rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data : 
             {};
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserData().get('role', '') == 'admin' || 
        getUserData().get('isAdmin', false) == true || // Legacy support
        request.auth.token.get('isAdmin', false) == true
      );
    }

    function isBanned() {
      return isSignedIn() && getUserData().get('isBanned', false) == true;
    }

    function isUserOnboardedAndActive(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)) && 
             get(/databases/$(database)/documents/users/$(userId)).data.get('onboardingCompleted', false) == true && 
             get(/databases/$(database)/documents/users/$(userId)).data.get('isBanned', false) == false;
    }

    function isValidActivityCreate(activityId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userExists = exists(userPath);
      let username = userExists ? get(userPath).data.get('username', null) : null;
      return (
        // 1. Authentifizierung & Onboarding
        isSignedIn() && 
        request.resource.data.hostId == request.auth.uid && 
        isUserOnboardedAndActive(request.auth.uid) &&
        
        // 2. Whitelist-Validierung
        request.resource.data.keys().hasOnly([
          'id', 'title', 'placeName', 'activityDate', 'activityEndDate', 'hostId', 'hostName', 'hostUsername', 'hostPhotoURL',
          'participantIds', 'participantsPreview', 'createdAt', 'lastInteractionAt', 'isCustomActivity',
          'isTimeFlexible', 'category', 'description', 'status', 'completionVotes', 'isBoosted', 'boostedAt',
          'isPaid', 'price', 'upvotes', 'downvotes', 'userVotes', 'globalScore', 'reportCount', 'avgRating',
          'reviewCount', 'stats', 'participantDetails', 'placeAddress', 'lat', 'lon', 'maxParticipants',
          'requirements', 'joinMode', 'placeId', 'categories', 'isUserEvent', 'sourceType', 'creationSource',
          'normalizedCategory', 'isDateFlexible', 'city', 'postalCode'
        ]) &&
        
        // 3. Typ- und Wertprüfungen
        request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 100 &&
        request.resource.data.placeName is string && request.resource.data.placeName.size() > 0 && request.resource.data.placeName.size() <= 100 &&
        request.resource.data.hostName is string && request.resource.data.hostName.size() > 0 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.lastInteractionAt == request.time &&
        request.resource.data.status in ['active', 'open'] &&
        request.resource.data.completionVotes == [] &&
        request.resource.data.upvotes == 0 &&
        request.resource.data.downvotes == 0 &&
        request.resource.data.userVotes == {} &&
        request.resource.data.globalScore == 0 &&
        request.resource.data.reportCount == 0 &&
        request.resource.data.avgRating == 0 &&
        request.resource.data.reviewCount == 0 &&
        request.resource.data.stats == {'impressions': 0, 'pushJoins': 0, 'referralJoins': 0} &&
        request.resource.data.sourceType == 'activity' &&
        request.resource.data.participantIds == [request.auth.uid] &&
        request.resource.data.participantsPreview is list && request.resource.data.participantsPreview.size() == 1 &&
        request.resource.data.participantsPreview[0].uid == request.auth.uid &&
        request.resource.data.participantsPreview[0].keys().hasOnly(['uid', 'displayName', 'photoURL', 'username']) &&
        
        request.resource.data.get('hostUsername', null) == username &&
        request.resource.data.participantsPreview[0].get('username', null) == request.resource.data.get('hostUsername', null) &&
        
        request.resource.data.participantDetails is map && request.resource.data.participantDetails.keys().hasOnly([request.auth.uid]) &&
        request.resource.data.participantDetails[request.auth.uid].keys().hasOnly(['displayName', 'photoURL', 'isPremium', 'isSupporter', 'checkInStatus', 'hasReviewed', 'username']) &&
        request.resource.data.participantDetails[request.auth.uid].get('checkInStatus', 'pending') == 'pending' &&
        request.resource.data.participantDetails[request.auth.uid].get('hasReviewed', false) == false &&
        request.resource.data.participantDetails[request.auth.uid].get('username', null) == request.resource.data.get('hostUsername', null) &&
        request.resource.data.isPaid == false &&
        request.resource.data.price == 0 &&
        
        // 4. Zeitvalidierung
        request.resource.data.activityDate is timestamp && 
        request.resource.data.activityDate >= request.time - duration.value(5, 'm') &&
        (!('activityEndDate' in request.resource.data) || (
          request.resource.data.activityEndDate is timestamp && 
          request.resource.data.activityEndDate > request.resource.data.activityDate && 
          request.resource.data.activityEndDate <= request.resource.data.activityDate + duration.value(30, 'd')
        )) &&
        
        // 5. Kapazitätsvalidierung
        (!('maxParticipants' in request.resource.data) || (
          request.resource.data.maxParticipants is int && 
          request.resource.data.maxParticipants >= 2 && 
          request.resource.data.maxParticipants <= 100
        )) &&
        
        // 6. Orts- und Koordinatenvalidierung
        (!('lat' in request.resource.data) || (request.resource.data.lat is number && request.resource.data.lat >= -90.0 && request.resource.data.lat <= 90.0)) &&
        (!('lon' in request.resource.data) || (request.resource.data.lon is number && request.resource.data.lon >= -180.0 && request.resource.data.lon <= 180.0)) &&
        (!('city' in request.resource.data) || (request.resource.data.city is string && request.resource.data.city.size() <= 100)) &&
        (!('postalCode' in request.resource.data) || (request.resource.data.postalCode is string && request.resource.data.postalCode.size() <= 20)) &&
        (!('placeAddress' in request.resource.data) || (request.resource.data.placeAddress is string && request.resource.data.placeAddress.size() <= 200)) &&
        (!('joinMode' in request.resource.data) || request.resource.data.joinMode in ['direct', 'request']) &&
        
        (request.resource.data.get('placeId', 'custom') == 'custom' || (
          request.resource.data.placeId is string &&
          existsAfter(/databases/$(database)/documents/places/$(request.resource.data.placeId)) && 
          getAfter(/databases/$(database)/documents/places/$(request.resource.data.placeId)).data.get('isDeleted', false) == false && 
          getAfter(/databases/$(database)/documents/places/$(request.resource.data.placeId)).data.get('isBlacklisted', false) == false &&
          getAfter(/databases/$(database)/documents/places/$(request.resource.data.placeId)).data.get('activityCount', 0) == (
            exists(/databases/$(database)/documents/places/$(request.resource.data.placeId)) ?
              get(/databases/$(database)/documents/places/$(request.resource.data.placeId)).data.get('activityCount', 0) + 1 :
              1
          )
        )) &&
        
        // 7. Boost- & Token-Deduction-Validierung
        request.resource.data.isBoosted is bool && (
          (request.resource.data.isBoosted == false && request.resource.data.boostedAt == null) ||
          (
            request.resource.data.isBoosted == true && 
            request.resource.data.boostedAt == request.time &&
            getUserData().get('tokens', 0) >= 1 &&
            getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.tokens == getUserData().get('tokens', 0) - 1
          )
        ) &&
        
        // 8. Chat- & Participant-Konsistenz
        existsAfter(/databases/$(database)/documents/chats/$(activityId)) && 
        getAfter(/databases/$(database)/documents/chats/$(activityId)).data.activityId == activityId && 
        getAfter(/databases/$(database)/documents/chats/$(activityId)).data.hostId == request.auth.uid &&
        existsAfter(/databases/$(database)/documents/activities/$(activityId)/participants/$(request.auth.uid))
      );
    }

    function isValidActivityUpdateNormal() {
      return (
        // 1. Host Authentifizierung & Onboarding
        isSignedIn() && 
        resource.data.hostId == request.auth.uid && 
        isUserOnboardedAndActive(request.auth.uid) &&
                   
        // 2. Keine Manipulation von System- oder Zahlungsfeldern
        request.resource.data.get('hostId', '') == resource.data.get('hostId', '') &&
        request.resource.data.get('hostUsername', null) == resource.data.get('hostUsername', null) &&
        request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null) &&
        request.resource.data.get('sourceType', '') == resource.data.get('sourceType', '') &&
        request.resource.data.get('isPaid', false) == resource.data.get('isPaid', false) &&
        request.resource.data.get('price', 0) == resource.data.get('price', 0) &&
        request.resource.data.get('participantIds', []).size() == resource.data.get('participantIds', []).size() &&
        request.resource.data.get('participantIds', []).hasAll(resource.data.get('participantIds', [])) &&
        request.resource.data.get('isBoosted', false) == resource.data.get('isBoosted', false) &&
        request.resource.data.get('boostedAt', null) == resource.data.get('boostedAt', null) &&
        (
          request.resource.data.get('status', '') == resource.data.get('status', '') || (
            resource.data.get('isPaid', false) == false &&
            request.resource.data.get('status', '') == 'cancelled'
          )
        ) &&
        
        // 4. Einschränkungen nach Teilnehmer-Beitritt
        (resource.data.participantIds.size() <= 1 || (
          // Ort unveränderlich
          request.resource.data.get('placeId', null) == resource.data.get('placeId', null) &&
          request.resource.data.get('placeName', null) == resource.data.get('placeName', null) &&
          request.resource.data.get('placeAddress', null) == resource.data.get('placeAddress', null) &&
          request.resource.data.get('lat', 0.0) == resource.data.get('lat', 0.0) &&
          request.resource.data.get('lon', 0.0) == resource.data.get('lon', 0.0) &&
          // Zeit unveränderlich
          request.resource.data.get('activityDate', null) == resource.data.get('activityDate', null) &&
          request.resource.data.get('activityEndDate', null) == resource.data.get('activityEndDate', null) &&
          request.resource.data.get('isTimeFlexible', null) == resource.data.get('isTimeFlexible', null) &&
          request.resource.data.get('isDateFlexible', false) == resource.data.get('isDateFlexible', false)
        )) &&
      
        // Kapazität nicht verringerbar oder unter aktuelle Teilnehmerzahl
        (request.resource.data.get('maxParticipants', 0) == resource.data.get('maxParticipants', 0) || (
          request.resource.data.maxParticipants is int &&
          request.resource.data.maxParticipants >= resource.data.get('maxParticipants', 0) &&
          request.resource.data.maxParticipants >= resource.data.participantIds.size()
        ))
      );
    }

    function isValidActivityUpdateBoost() {
      return (
        // 1. Host Authentifizierung & Onboarding
        isSignedIn() && 
        resource.data.hostId == request.auth.uid && 
        isUserOnboardedAndActive(request.auth.uid) &&
                   
        // 2. Keine Manipulation von System- oder Zahlungsfeldern
        request.resource.data.get('hostId', '') == resource.data.get('hostId', '') &&
        request.resource.data.get('hostUsername', null) == resource.data.get('hostUsername', null) &&
        request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null) &&
        request.resource.data.get('sourceType', '') == resource.data.get('sourceType', '') &&
        request.resource.data.get('isPaid', false) == resource.data.get('isPaid', false) &&
        request.resource.data.get('price', 0) == resource.data.get('price', 0) &&
        request.resource.data.get('participantIds', []).size() == resource.data.get('participantIds', []).size() &&
        request.resource.data.get('participantIds', []).hasAll(resource.data.get('participantIds', [])) &&
        request.resource.data.get('status', '') == resource.data.get('status', '') &&
        
        resource.data.get('isBoosted', false) == false && 
        request.resource.data.get('isBoosted', false) == true &&
        request.resource.data.boostedAt == request.time &&
        getUserData().get('tokens', 0) >= 1 &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.tokens == getUserData().tokens - 1
      );
    }

    function isValidDirectJoin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userExists = exists(userPath);
      let username = userExists ? get(userPath).data.get('username', null) : null;
      return (
        isSignedIn() &&
        isUserOnboardedAndActive(request.auth.uid) &&
        'joinMode' in resource.data && resource.data.joinMode == 'direct' &&
        resource.data.status == 'active' &&
        resource.data.isPaid == false &&
        
        (!('maxParticipants' in resource.data) || resource.data.get('participantIds', []).size() < resource.data.maxParticipants) &&
        
        // Exact participantIds mutation (append caller only)
        request.resource.data.get('participantIds', []).size() == resource.data.get('participantIds', []).size() + 1 &&
        request.auth.uid in request.resource.data.get('participantIds', []) &&
        request.resource.data.get('participantIds', []).hasAll(resource.data.get('participantIds', [])) &&
        
        // Exact participantsPreview mutation (append caller only)
        'participantsPreview' in request.resource.data && request.resource.data.participantsPreview is list &&
        request.resource.data.participantsPreview.size() == resource.data.get('participantsPreview', []).size() + 1 &&
        request.resource.data.participantsPreview[request.resource.data.participantsPreview.size() - 1].uid == request.auth.uid &&
        request.resource.data.participantsPreview[request.resource.data.participantsPreview.size() - 1].keys().hasOnly(['uid', 'displayName', 'photoURL', 'username']) &&
        request.resource.data.participantsPreview[request.resource.data.participantsPreview.size() - 1].get('username', null) == username &&
        
        // Exact participantDetails mutation (caller's entry added)
        'participantDetails' in request.resource.data && request.resource.data.participantDetails is map &&
        request.resource.data.participantDetails.keys().size() == resource.data.get('participantDetails', {}).keys().size() + 1 &&
        request.auth.uid in request.resource.data.participantDetails &&
        request.resource.data.participantDetails.get(request.auth.uid, {}).keys().hasOnly(['displayName', 'photoURL', 'isPremium', 'isSupporter', 'checkInStatus', 'hasReviewed', 'username']) &&
        request.resource.data.participantDetails.get(request.auth.uid, {}).get('checkInStatus', 'pending') == 'pending' &&
        request.resource.data.participantDetails.get(request.auth.uid, {}).get('hasReviewed', false) == false &&
        request.resource.data.participantDetails.get(request.auth.uid, {}).get('username', null) == username &&
        
        // Stats can only increment pushJoins or referralJoins
        request.resource.data.get('stats', {}).get('pushJoins', 0) <= resource.data.get('stats', {}).get('pushJoins', 0) + 1 &&
        request.resource.data.get('stats', {}).get('referralJoins', 0) <= resource.data.get('stats', {}).get('referralJoins', 0) + 1
      );
    }
 
    function isValidDirectLeave() {
      return (
        isSignedIn() &&
        isUserOnboardedAndActive(request.auth.uid) &&
        'joinMode' in resource.data && resource.data.joinMode == 'direct' &&
        resource.data.status == 'active' &&
        resource.data.isPaid == false &&
        
        // Exact participantIds mutation (remove caller only)
        request.resource.data.get('participantIds', []).size() == resource.data.get('participantIds', []).size() - 1 &&
        !(request.auth.uid in request.resource.data.get('participantIds', [])) &&
        resource.data.get('participantIds', []).hasAll(request.resource.data.get('participantIds', [])) &&
        
        // Exact participantsPreview mutation (remove caller only)
        (!('participantsPreview' in request.resource.data) || (
          request.resource.data.participantsPreview is list &&
          request.resource.data.participantsPreview.size() == resource.data.get('participantsPreview', []).size() - 1
        )) &&
        
        // Exact participantDetails mutation (caller's entry deleted or nullified)
        (!('participantDetails' in request.resource.data) || (
          request.resource.data.participantDetails is map &&
          (
            !(request.auth.uid in request.resource.data.participantDetails) ||
            request.resource.data.participantDetails[request.auth.uid] == null
          )
        ))
      );
    }

    function isParticipantAllowedUpdate() {
      let uid = request.auth.uid;
      
      let reqVotes = request.resource.data.get('completionVotes', []);
      let resVotes = resource.data.get('completionVotes', []);
         
      return (
        isSignedIn() &&
        resource.data.participantIds.hasAny([uid]) &&
        
        // Check changed fields manually to avoid diff()
        request.resource.data.get('title', '') == resource.data.get('title', '') &&
        request.resource.data.get('description', '') == resource.data.get('description', '') &&
        request.resource.data.get('participantIds', []) == resource.data.get('participantIds', []) &&
        request.resource.data.get('participantDetails', {}) == resource.data.get('participantDetails', {}) &&
        
        reqVotes.size() == resVotes.size() + 1 &&
        uid in reqVotes &&
        reqVotes.hasAll(resVotes)
      );
    }

    function isValidUnreadCountUpdate(uid, oldData, newData) {
      let unreadDiff = newData.unreadCount.diff(oldData.unreadCount);
      let affected = unreadDiff.affectedKeys();
      
      // Case 1: markChatAsRead (resetting own unreadCount to 0)
      return affected.hasOnly([uid]) && 
             newData.unreadCount.get(uid, 0) == 0;
    }

    function isValidChatMessageMetadataUpdate(chatId) {
      let uid = request.auth.uid;
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let isParticipant = resource.data.participantIds.hasAny([uid]);
      
      // Restrict pinnedMessages changes to chat host or admin
      let isPinAllowed = !changedKeys.hasAny(['pinnedMessages']) || 
                         resource.data.get('hostId', '') == uid;
      
      return isSignedIn() &&
             isParticipant &&
             changedKeys.hasOnly(['lastMessage', 'lastActivityAt', 'lastMessageAt', 'unreadCount', 'pinnedMessages']) &&
             isPinAllowed &&
             (!changedKeys.hasAny(['unreadCount']) || isValidUnreadCountUpdate(uid, resource.data, request.resource.data));
    }

    function isValidChatDirectJoin(chatId) {
      let uid = request.auth.uid;
      
      let isActivityChat = 'activityId' in resource.data && resource.data.activityId == chatId;
      let isParticipantInActivity = existsAfter(/databases/$(database)/documents/activities/$(chatId)) &&
                                     getAfter(/databases/$(database)/documents/activities/$(chatId)).data.participantIds.hasAny([uid]);
      
      let username = getUserData().get('username', null);

      return (
        isSignedIn() &&
        isActivityChat &&
        isParticipantInActivity &&
        !(uid in resource.data.participantIds) &&
        
        request.resource.data.get('hostId', '') == resource.data.get('hostId', '') &&
        
        request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1 &&
        request.resource.data.participantIds.hasAll(resource.data.participantIds) &&
        uid in request.resource.data.participantIds &&
        
        request.resource.data.participantDetails.keys().hasAll(resource.data.participantDetails.keys()) &&
        request.resource.data.participantDetails.keys().size() == resource.data.participantDetails.keys().size() + 1 &&
        uid in request.resource.data.participantDetails &&
        request.resource.data.participantDetails.get(uid, {}).keys().hasOnly(['displayName', 'photoURL', 'isPremium', 'isSupporter', 'checkInStatus', 'username']) &&
        request.resource.data.participantDetails.get(uid, {}).get('checkInStatus', 'pending') == 'pending' &&
        request.resource.data.participantDetails.get(uid, {}).get('username', null) == username &&
        
        request.resource.data.unreadCount.keys().hasAll(resource.data.unreadCount.keys()) &&
        request.resource.data.unreadCount.keys().size() == resource.data.unreadCount.keys().size() + 1 &&
        uid in request.resource.data.unreadCount &&
        request.resource.data.unreadCount.get(uid, 0) == 0
      );
    }

    function isValidChatOwnCleanup(chatId) {
      let uid = request.auth.uid;
      let isParticipant = resource.data.participantIds.hasAny([uid]);

      return (
        isSignedIn() &&
        isParticipant &&
        
        !(uid in request.resource.data.participantIds) &&
        request.resource.data.participantIds.size() == resource.data.participantIds.size() - 1 &&
        
        !(uid in request.resource.data.participantDetails) &&
        request.resource.data.participantDetails.size() == resource.data.participantDetails.size() - 1 &&
        
        !(uid in request.resource.data.unreadCount) &&
        request.resource.data.unreadCount.size() == resource.data.unreadCount.size() - 1
      );
    }

    function isValidNotificationLink(link) {
      return link == null || 
             link.matches('^/users/[a-zA-Z0-9_-]+$') || 
             link.matches('^/activities/[a-zA-Z0-9_-]+$') || 
             link.matches('^/chat/[a-zA-Z0-9_-]+$') || 
             link == '/wallet' || 
             link == '/profile';
    }

    function activityAfter(activityId) {
      return getAfter(/databases/$(database)/documents/activities/$(activityId));
    }

    function activityAfterData(activityId) {
      return activityAfter(activityId).data;
    }

    function isChatActive(chatId) {
      let chatPath = /databases/$(database)/documents/chats/$(chatId);
      let chatExists = exists(chatPath);
      let chatData = chatExists ? get(chatPath).data : {};
      let activityId = chatExists ? chatData.get('activityId', '') : '';
      let hasNoActivity = activityId == null || activityId == '';
      let activityPath = !hasNoActivity ? /databases/$(database)/documents/activities/$(activityId) : /databases/$(database)/documents/activities/dummy;
      let activityExists = !hasNoActivity ? exists(activityPath) : false;
      let activityData = activityExists ? get(activityPath).data : {};
      let activityStatus = activityExists ? activityData.get('status', '') : '';
      return chatExists && (hasNoActivity || (activityExists && (activityStatus == 'active' || activityStatus == 'open')));
    }

    function validateOwnerUpdate() {
      let data = request.resource.data;
      return (
        (!('fcmToken' in data) || data.fcmToken == null || (data.fcmToken is string && data.fcmToken.size() > 0 && data.fcmToken.size() < 500)) &&
        (!('notificationSettings' in data) || (
          data.notificationSettings is map &&
          data.notificationSettings.keys().hasOnly(['localHighlights', 'nearbyFriendActivityNotifications', 'friendRequests', 'activityInvites', 'chatMessages']) &&
          data.notificationSettings.get('localHighlights', false) is bool &&
          data.notificationSettings.get('nearbyFriendActivityNotifications', true) is bool &&
          data.notificationSettings.get('friendRequests', true) is bool &&
          data.notificationSettings.get('activityInvites', true) is bool &&
          data.notificationSettings.get('chatMessages', true) is bool
        )) &&
        (!('proximitySettings' in data) || (
          data.proximitySettings is map &&
          data.proximitySettings.keys().hasOnly(['enabled', 'radiusKm']) &&
          data.proximitySettings.get('enabled', false) is bool &&
          data.proximitySettings.get('radiusKm', 5) is int &&
          data.proximitySettings.get('radiusKm', 5) >= 1 &&
          data.proximitySettings.get('radiusKm', 5) <= 50
        )) &&
        (!('language' in data) || data.language in ['de', 'en'])
      );
    }

    // Verhindert das Ändern von Systemfeldern durch den Client
    function hasNoSystemFieldChanges() {
      return (
        request.resource.data.get('role', '') == resource.data.get('role', '') &&
        request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false) &&
        request.resource.data.get('isBanned', false) == resource.data.get('isBanned', false) &&
        request.resource.data.get('escrowBalance', 0) == resource.data.get('escrowBalance', 0) &&
        request.resource.data.get('fiatBalance', 0) == resource.data.get('fiatBalance', 0) &&
        request.resource.data.get('balancesInCents', true) == resource.data.get('balancesInCents', true) &&
        request.resource.data.get('successfulFreeHosts', 0) == resource.data.get('successfulFreeHosts', 0) &&
        request.resource.data.get('kycStatus', 'unverified') == resource.data.get('kycStatus', 'unverified') &&
        request.resource.data.get('ratingCount', 0) == resource.data.get('ratingCount', 0) &&
        request.resource.data.get('averageRating', 0) == resource.data.get('averageRating', 0) &&
        request.resource.data.get('isPremium', false) == resource.data.get('isPremium', false) &&
        request.resource.data.get('isSupporter', false) == resource.data.get('isSupporter', false) &&
        request.resource.data.get('isCreator', false) == resource.data.get('isCreator', false) &&
        request.resource.data.get('premiumEntitlements', []) == resource.data.get('premiumEntitlements', []) &&
        request.resource.data.get('successfulReferrals', 0) == resource.data.get('successfulReferrals', 0) &&
        request.resource.data.get('blacklist', {}).get('hard', []) == resource.data.get('blacklist', {}).get('hard', []) &&
        request.resource.data.get('blacklist', {}).get('soft', []) == resource.data.get('blacklist', {}).get('soft', []) &&
        request.resource.data.get('emailVerificationRequired', false) == resource.data.get('emailVerificationRequired', false) &&
        request.resource.data.get('emailVerificationProvider', '') == resource.data.get('emailVerificationProvider', '') &&
        request.resource.data.get('emailVerificationReason', '') == resource.data.get('emailVerificationReason', '') &&
        request.resource.data.get('emailVerificationCreatedAt', null) == resource.data.get('emailVerificationCreatedAt', null) &&
        request.resource.data.get('emailVerifiedAt', null) == resource.data.get('emailVerifiedAt', null) &&
        request.resource.data.get('verificationEmailLastSentAt', null) == resource.data.get('verificationEmailLastSentAt', null) &&
        request.resource.data.get('pointsBalance', 0) == resource.data.get('pointsBalance', 0) &&
        request.resource.data.get('pointsLifetime', 0) == resource.data.get('pointsLifetime', 0) &&
        request.resource.data.get('level', 1) == resource.data.get('level', 1) &&
        request.resource.data.get('referralCode', '') == resource.data.get('referralCode', '') &&
        request.resource.data.get('referredBy', '') == resource.data.get('referredBy', '') &&
        request.resource.data.get('username', '') == resource.data.get('username', '') &&
        request.resource.data.get('usernameLowercase', '') == resource.data.get('usernameLowercase', '') &&
        request.resource.data.get('usernameLastChangedAt', null) == resource.data.get('usernameLastChangedAt', null) &&
        request.resource.data.get('usernameChangeHistory', []).size() == resource.data.get('usernameChangeHistory', []).size() &&
        request.resource.data.get('friends', []) == resource.data.get('friends', []) &&
        request.resource.data.get('friendRequestsSent', []) == resource.data.get('friendRequestsSent', []) &&
        request.resource.data.get('friendRequestsReceived', []) == resource.data.get('friendRequestsReceived', []) &&
        
        (
          request.resource.data.get('tokens', 0) == resource.data.get('tokens', 0) ||
          (
            request.resource.data.get('tokens', 0) is int &&
            resource.data.get('tokens', 0) is int &&
            request.resource.data.get('tokens', 0) == resource.data.get('tokens', 0) - 1 &&
            request.resource.data.get('tokens', 0) >= 0
          )
        )
      );
    }

    function hasNoImmutableFinancialFieldChanges() {
      let immutableFields = ['price', 'isPaid', 'hostId', 'currency', 'paymentConfig'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(immutableFields);
    }

    function hasNoPaidActivityFieldChanges() {
      let forbiddenKeys = [
        'participantIds', 'participantsPreview', 'participantDetails', 
        'completionVotes', 'status', 'price', 'isPaid', 'hostId', 
        'currency', 'paymentConfig'
      ];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(forbiddenKeys);
    }

    function hasNoActivityVoteFieldChanges() {
      return request.resource.data.get('communityScore', 0) == resource.data.get('communityScore', 0) &&
             request.resource.data.get('userVotes', {}) == resource.data.get('userVotes', {}) &&
             request.resource.data.get('userVoteWeights', {}) == resource.data.get('userVoteWeights', {}) &&
             request.resource.data.get('globalScore', 0) == resource.data.get('globalScore', 0) &&
             request.resource.data.get('weightedUpvotes', 0) == resource.data.get('weightedUpvotes', 0) &&
             request.resource.data.get('weightedDownvotes', 0) == resource.data.get('weightedDownvotes', 0) &&
             request.resource.data.get('voteBoostScore', 0) == resource.data.get('voteBoostScore', 0);
    }

    function isValidDirectChat(participantIds, participantDetails) {
      let uid = request.auth.uid;
      let otherUid = participantIds[0] == uid ? participantIds[1] : participantIds[0];
      
      let creatorPath = /databases/$(database)/documents/users/$(uid);
      let otherPath = /databases/$(database)/documents/users/$(otherUid);
      
      let creatorExists = exists(creatorPath);
      let otherExists = exists(otherPath);
      
      let creatorData = creatorExists ? get(creatorPath).data : {};
      let otherData = otherExists ? get(otherPath).data : {};
      
      let myUsername = creatorData.get('username', null);
      let otherUsername = otherData.get('username', null);
      
      return creatorExists && otherExists &&
             creatorData.get('isBanned', false) == false &&
             otherData.get('isBanned', false) == false &&
             !(uid in otherData.get('blacklist', {}).get('hard', [])) &&
             !(uid in otherData.get('blacklist', {}).get('soft', [])) &&
             !(otherUid in creatorData.get('blacklist', {}).get('hard', [])) &&
             !(otherUid in creatorData.get('blacklist', {}).get('soft', [])) &&
             participantDetails.keys().hasOnly(participantIds) &&
             participantDetails.get(uid, {}).keys().hasOnly(['displayName', 'photoURL', 'isPremium', 'isSupporter', 'username']) &&
             participantDetails.get(otherUid, {}).keys().hasOnly(['displayName', 'photoURL', 'isPremium', 'isSupporter', 'username']) &&
             participantDetails.get(uid, {}).get('username', null) == myUsername &&
             participantDetails.get(otherUid, {}).get('username', null) == otherUsername;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && 
        request.resource.data.role == 'user' && 
        request.resource.data.isBanned == false &&
        request.resource.data.escrowBalance == 0 &&
        request.resource.data.fiatBalance == 0 &&
        request.resource.data.balancesInCents == true &&
        request.resource.data.kycStatus == 'unverified' &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false) &&
        request.resource.data.tokens == 0 &&
        request.resource.data.successfulFreeHosts == 0 &&
        request.resource.data.averageRating == 0 &&
        request.resource.data.ratingCount == 0 &&
        request.resource.data.successfulReferrals == 0 &&
        request.resource.data.isPremium == false &&
        request.resource.data.isSupporter == false &&
        request.resource.data.isCreator == false &&
        (!('premiumEntitlements' in request.resource.data) || request.resource.data.premiumEntitlements.size() == 0) &&
        (!('pointsBalance' in request.resource.data) || request.resource.data.pointsBalance == 0) &&
        (!('pointsLifetime' in request.resource.data) || request.resource.data.pointsLifetime == 0) &&
        (!('level' in request.resource.data) || request.resource.data.level == 1) &&
        (!('referralCode' in request.resource.data)) &&
        (!('referredBy' in request.resource.data)) &&
        (!('username' in request.resource.data)) &&
        (!('usernameLowercase' in request.resource.data)) &&
        (!('usernameLastChangedAt' in request.resource.data)) &&
        (!('usernameChangeHistory' in request.resource.data)) &&
        validateOwnerUpdate();
      
      // Removed social update bypass completely.
      // System fields list in hasNoSystemFieldChanges now strictly covers friends, friendRequestsSent, and friendRequestsReceived.
      allow update: if (isOwner(userId) && hasNoSystemFieldChanges() && validateOwnerUpdate()) || 
                       isAdmin();
      allow delete: if isAdmin();

      match /pointsLedger/{entryId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /tokenTransactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Username lock collection — managed exclusively by Cloud Functions / Admin SDK.
    match /usernames/{usernameLower} {
      allow read: if false;
      allow write: if false;
    }

    match /activities/{activityId} {
      allow read: if true;
      allow create: if isValidActivityCreate(activityId);
      allow update: if isSignedIn() && (
        request.resource.data.get('participantIds', []) == resource.data.get('participantIds', []) ?
          (
            (resource.data.get('isBoosted', false) == false && request.resource.data.get('isBoosted', false) == true) ?
              (isValidActivityUpdateBoost() || isAdmin()) :
              (isValidActivityUpdateNormal() || isParticipantAllowedUpdate() || isAdmin())
          ) :
          (
            (request.auth.uid in resource.data.participantIds) ?
              (isValidDirectLeave() || isAdmin()) :
              (isValidDirectJoin() || isAdmin())
          )
      );
      // Activity deletion is cloud function / admin sdk owned. Client delete restricted to isAdmin().
      allow delete: if isAdmin();
      
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          isAdmin() || 
          (
            request.auth.uid == participantId &&
            existsAfter(/databases/$(database)/documents/activities/$(activityId)) &&
            activityAfterData(activityId).participantIds.hasAny([participantId]) &&
            (
              activityAfterData(activityId).isPaid == false ||
              activityAfterData(activityId).hostId == request.auth.uid
            ) &&
            request.resource.data.uid == request.auth.uid &&
            request.resource.data.checkInStatus == 'pending' &&
            request.resource.data.hasReviewed == false
          )
        );
        allow update: if isSignedIn() && (
          isAdmin() ||
          // Case 1: Participant updates their own details (non-system fields)
          (
            request.auth.uid == participantId &&
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'joinedAt'])
          ) ||
          // Case 2: Host updates check-in status/time
          (
            get(/databases/$(database)/documents/activities/$(activityId)).data.hostId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkInStatus', 'checkInTime'])
          )
        );
        // Leaving participants delete is cloud function owned. Client delete restricted to isAdmin().
        allow delete: if isAdmin();
      }
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin()
      );
      allow create: if isSignedIn() && (
        // Case 1: Activity-based chat
        (
          request.resource.data.hostId == request.auth.uid &&
          request.resource.data.participantIds.size() == 1 &&
          request.resource.data.participantIds[0] == request.auth.uid &&
          request.resource.data.activityId == chatId &&
          existsAfter(/databases/$(database)/documents/activities/$(chatId)) &&
          activityAfterData(chatId).hostId == request.auth.uid
        ) ||
        // Case 2: Direct message chat
        (
          request.resource.data.get('type', '') == 'direct' &&
          !('activityId' in request.resource.data) &&
          !('hostId' in request.resource.data) &&
          !('lastMessage' in request.resource.data) &&
          !('unreadCount' in request.resource.data) &&
          request.resource.data.participantIds.size() == 2 &&
          request.auth.uid in request.resource.data.participantIds &&
          request.resource.data.keys().hasOnly(['type', 'participantIds', 'createdAt', 'lastActivityAt', 'participantDetails']) &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.lastActivityAt == request.time &&
          isValidDirectChat(request.resource.data.participantIds, request.resource.data.participantDetails)
        )
      );
      // Chat update uses granular, secure helpers.
      allow update: if isSignedIn() && (
        isValidChatMessageMetadataUpdate(chatId) ||
        isValidChatDirectJoin(chatId) ||
        isValidChatOwnCleanup(chatId) || 
        isAdmin()
      );
      allow delete: if false;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) || 
          isAdmin()
        );
        
        allow create: if false;
          
        allow update: if isSignedIn() && 
          get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) &&
          resource.data.senderId == request.auth.uid &&
          isChatActive(chatId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'isEdited', 'editedAt']) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['editedAt']) || request.resource.data.editedAt == request.time) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 2000 &&
          request.resource.data.text.matches('.*\\S.*');
          
        allow delete: if isSignedIn() && (
          (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) &&
            (resource.data.senderId == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.hostId == request.auth.uid)
          ) || 
          isAdmin()
        );
      }
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid || isAdmin()
      );

      allow create: if false;

      allow update: if isSignedIn() && (
        (
          resource.data.recipientId == request.auth.uid &&
          request.resource.data.get('recipientId', '') == resource.data.get('recipientId', '') &&
          request.resource.data.get('senderId', '') == resource.data.get('senderId', '') &&
          request.resource.data.get('type', '') == resource.data.get('type', '') &&
          request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null) &&
          request.resource.data.get('senderProfile', {}).get('displayName', '') == resource.data.get('senderProfile', {}).get('displayName', '') &&
          request.resource.data.get('senderProfile', {}).get('photoURL', null) == resource.data.get('senderProfile', {}).get('photoURL', null) &&
          request.resource.data.get('link', null) == resource.data.get('link', null) &&
          request.resource.data.get('activityId', '') == resource.data.get('activityId', '') &&
          request.resource.data.get('title', '') == resource.data.get('title', '') &&
          request.resource.data.get('message', '') == resource.data.get('message', '') &&
          
          request.resource.data.isRead == true &&
          (!('readAt' in request.resource.data) || request.resource.data.readAt == request.time)
        ) ||
        isAdmin()
      );

      allow delete: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid || isAdmin()
      );
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.reporterId == request.auth.uid &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'open') &&
        (
          request.resource.data.keys().hasOnly(['reporterId', 'reportedEntityId', 'entityType', 'reason', 'status', 'createdAt']) ||
          request.resource.data.keys().hasOnly(['reporterId', 'activityId', 'reason', 'status', 'createdAt'])
        );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /creator_applications/{appId} {
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid && 
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasOnly(['userId', 'userDisplayName', 'averageRating', 'activitiesCount', 'status', 'createdAt']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /boosts/{boostId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasOnly(['userId', 'entityId', 'entityType', 'createdAt', 'expiresAt', 'boostLevel', 'multiplier']) &&
        request.resource.data.userId is string &&
        request.resource.data.entityId is string &&
        request.resource.data.entityType in ['activity', 'place'] &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.expiresAt > request.time &&
        request.resource.data.boostLevel is int &&
        request.resource.data.multiplier is number;
      allow update, delete: if isAdmin();
    }

    match /places/{placeId} {
      // Places require authenticated/onboarded read.
      allow read: if isSignedIn() && isUserOnboardedAndActive(request.auth.uid);
      
      allow create: if isSignedIn() && 
        !request.resource.data.keys().hasAny([
          'upvotes', 'downvotes', 'weightedUpvotes', 'weightedDownvotes',
          'weightedCommunityScore', 'communityScore', 'globalScore',
          'userVotes', 'userVoteWeights', 'voteBoostScore'
        ]) &&
        request.resource.data.get('activityCount', 0) == 1 &&
        existsAfter(/databases/$(database)/documents/activities/$(request.resource.data.get('lastActivityId', ''))) &&
        getAfter(/databases/$(database)/documents/activities/$(request.resource.data.lastActivityId)).data.get('placeId', '') == placeId;

      allow update: if isSignedIn() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'upvotes', 'downvotes', 'weightedUpvotes', 'weightedDownvotes',
          'weightedCommunityScore', 'communityScore', 'globalScore',
          'userVotes', 'userVoteWeights', 'voteBoostScore'
        ]) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['activityCount']) ||
          (
            request.resource.data.activityCount is int &&
            request.resource.data.activityCount == resource.data.get('activityCount', 0) + 1 &&
            'lastActivityId' in request.resource.data &&
            request.resource.data.lastActivityId is string &&
            existsAfter(/databases/$(database)/documents/activities/$(request.resource.data.lastActivityId)) &&
            getAfter(/databases/$(database)/documents/activities/$(request.resource.data.lastActivityId)).data.get('placeId', '') == placeId &&
            getAfter(/databases/$(database)/documents/activities/$(request.resource.data.lastActivityId)).data.get('hostId', '') == request.auth.uid
          )
        ) &&
        // Do not allow arbitrary overwrites of existing name/address/lat/lon/categories on update without increments (creating activity)
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'address', 'categories', 'lat', 'lon', 'openingHours']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['activityCount'])
        );
    }

    match /payoutRequests/{requestId} {
      allow create: if false; // Cloud Functions owned
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /refunds/{refundId} {
      allow create: if false; // Cloud Functions owned
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /financial_ledger/{entryId} {
      allow create: if false; // Cloud Functions owned
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /processed_payments/{docId} {
      allow create: if false;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /processed_operations/{docId} {
      allow create: if false;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /failed_operations/{docId} {
      allow create: if false;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
    
    match /kycRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telemetry_events/{eventId} {
      allow create: if isSignedIn() && 
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        'entity_id' in request.resource.data &&
        'event_type' in request.resource.data &&
        'event_value' in request.resource.data &&
        'timestamp' in request.resource.data &&
        request.resource.data.event_type in ['click', 'impression', 'dwell', 'card_open', 'favorite', 'share', 'directions'] &&
        (request.resource.data.event_value is int || request.resource.data.event_value is float) &&
        request.resource.data.keys().hasOnly(['entity_id', 'event_type', 'event_value', 'timestamp', 'user_id', 'placeId', 'interactionType', 'value', 'userId', 'category']);
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}