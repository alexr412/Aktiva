rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserData().role == 'admin' || 
        getUserData().isAdmin == true || // Legacy support
        request.auth.token.isAdmin == true
      );
    }

    function isFieldUnchanged(fieldName) {
      return !(fieldName in request.resource.data) || 
        (fieldName in resource.data && request.resource.data[fieldName] == resource.data[fieldName]);
    }

    // Verhindert das Ändern von Systemfeldern durch den Client
    function hasNoSystemFieldChanges() {
      let systemFields = [
        'role', 'isAdmin', 'isBanned', 'escrowBalance', 'fiatBalance', 
        'tokens', 'successfulFreeHosts', 'kycStatus', 'ratingCount', 'averageRating'
      ];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(systemFields);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
        request.resource.data.role == 'user' && 
        request.resource.data.isBanned == false &&
        request.resource.data.escrowBalance == 0;
      allow update: if (isOwner(userId) && hasNoSystemFieldChanges()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if true; // Öffentlich findbar
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid || 
        request.resource.data.participantIds.hasAny([request.auth.uid]) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.hostId == request.auth.uid || isAdmin());
      
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == participantId || isAdmin());
      }
    }

    match /chats/{chatId} {
      // Nur Teilnehmer dürfen den Chat-Metadaten-Doc lesen
      allow read: if isSignedIn() && (
        resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin()
      );
      // Erstellung nur wenn man selbst Teilnehmer ist
      allow create: if isSignedIn() && request.resource.data.participantIds.hasAny([request.auth.uid]);
      // Update nur für Teilnehmer (z.B. unreadCount oder neue Teilnehmer via Transaction)
      allow update: if isSignedIn() && (
        resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin()
      );
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        // Nur Teilnehmer dürfen Nachrichten lesen und schreiben
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) || 
          isAdmin()
        );
      }
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn(); // Erlaubt anderen, Notifications zu triggern (z.B. Join)
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /places/{placeId} {
      allow read: if true;
      // Feld-Level Security für Places: Verhindert Manipulation von Scores durch direkte API-Writes
      allow write: if isSignedIn() && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['communityScore', 'globalScore', 'activityCount']) ||
        isAdmin()
      );
    }

    match /payoutRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /refunds/{refundId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /kycRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telemetry_events/{eventId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
